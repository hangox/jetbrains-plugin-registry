{
  "name": "jetbrains-plugin-registry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "test": "bun test",
    "test:e2e": "bun run ../scripts/integration-test.ts",
    "test:e2e:sample": "bun run ../scripts/integration-test.ts --use-sample"
  },
  "dependencies": {
    "hono": "^4.12.0",
    "drizzle-orm": "^0.38.0",
    "adm-zip": "^0.5.16",
    "@hono/zod-validator": "^0.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "bun-types": "^1.3.9",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
